standalone_entrypoint = "127.0.0.1:14552"

[router]
listen = "0.0.0.0:14550"
tcp_port = 0
# Leave endpoints unset to forward to standalone_entrypoint by default.
# Add [[router.endpoints]] only when you need extra fan-out targets.
#
# [[router.endpoints]]
# name = "mac"
# endpoint = "100.68.243.25:14552"
#
# [[router.endpoints]]
# name = "qgc"
# endpoint = "127.0.0.1:14560"

[gazebo]
container_name = "compose-gazebo-1"
world = "/workspace/worlds/uav_obstacle_5m.sdf"

[foxglove]
container_name = "compose-foxglove-1"
port = 8765

[sim]
stop_distance = 0.5

[sim.logging]
console_level = "DEBUG"
file_level = "INFO"

[sim.x2_protocol]
enabled = false
profile = "profiles/x2-vendor-sim.yaml"
virtual_serial_link = "/tmp/navlab_x2"
scan_ideal_topic = "/scan_ideal"
scan_topic = "/scan"
status_topic = "/sim/x2/status"
sample_rate_hz = 3000.0
scan_frequency_hz = 7.0
scan_frequency_min_hz = 4.0
scan_frequency_max_hz = 8.0
range_min_m = 0.1
range_max_m = 8.0

[fast_lio]
container_name = "compose-fast-lio-1"
config_path = "/workspace/profiles/fast-lio/config.yaml"

[navlab.images]
tag_strategy = "latest"

[navlab.images.companion]
dockerfile = "docker/Dockerfile.companion"
context = "."
target = "navlab-companion"
repository = "world-model/navlab-companion"

[navlab.images.slam]
dockerfile = "docker/Dockerfile.companion"
context = "."
target = "navlab-slam-cartographer"
repository = "world-model/navlab-slam-cartographer"

[navlab.images.gazebo_sensor]
dockerfile = "docker/Dockerfile.companion"
context = "."
target = "navlab-gazebo-sensor"
repository = "world-model/navlab-gazebo-sensor"
