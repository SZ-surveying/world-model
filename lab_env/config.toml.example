standalone_entrypoint = "127.0.0.1:14552"

[router]
listen = "0.0.0.0:14550"
tcp_port = 0
# Leave endpoints unset to forward to standalone_entrypoint by default.
# Add [[router.endpoints]] only when you need extra fan-out targets.
