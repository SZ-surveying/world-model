[gazebo]
container_name = "compose-gazebo-1"
world = "/workspace/worlds/uav_obstacle_5m.sdf"

[foxglove]
container_name = "compose-foxglove-1"
port = 8765

[rosbag]
container_name = "compose-rosbag-record-1"
topic_file = "/workspace/profiles/rosbag-topics.txt"

[fast_lio]
container_name = "compose-fast-lio-1"
config_path = "/workspace/profiles/fast-lio/config.yaml"
