# NavLab SITL ExternalNav defaults.
# Uses MAVLink visual odometry as the GPS-denied position source.
FRAME_CLASS 1
FRAME_TYPE 1
MOT_PWM_MIN 1100
MOT_PWM_MAX 1900
AHRS_EKF_TYPE 3
EK3_ENABLE 1
EK2_ENABLE 0
GPS_TYPE 0
GPS1_TYPE 0
ARMING_CHECK 0
VISO_TYPE 3
VISO_POS_X 0
VISO_POS_Y 0
VISO_POS_Z 0
EK3_SRC1_POSXY 6
EK3_SRC1_VELXY 6
EK3_SRC1_POSZ 1
EK3_SRC1_VELZ 0
EK3_SRC1_YAW 6
